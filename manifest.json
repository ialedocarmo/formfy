{
  "manifest_version": 3,
  "name": "formly | Preenchimento manual e seguro",
  "short_name": "formly",
  "description": "Extensão para preenchimento de formulários com dados salvos localmente no navegador.",
  "version": "1.0.0",
  "author": "@ialedocarmo",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "formly",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "shared/content-config.js",
        "shared/content-heuristics.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
